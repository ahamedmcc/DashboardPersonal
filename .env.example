# Personal Command Dashboard — environment variables
# Copy this file to `.env` and fill in the actual values.
# Never commit `.env` to git.

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Telegram chat id used for sending notifications back to the user.
TELEGRAM_CHAT_ID=

# Shared secret required by POST /api/telegram/webhook (header: X-Webhook-Secret).
# Generate a strong value before deploy, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=

# Public base URL of the running app (used for webhook callbacks etc.).
APP_BASE_URL=http://localhost:3000

# Secret used by NextAuth / session signing.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
